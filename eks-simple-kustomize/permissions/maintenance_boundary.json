{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCommonActions",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:*",
        "ec2:*",
        "eks:*",
        "iam:*",
        "s3:*",
        "ecr:*",
        "acm:*",
        "Route53:*",
        "kms:*",
        "organizations:DescribeOrganization",
        "elasticloadbalancing:*"
      ],
      "Resource": "*"
    }
  ]
}
