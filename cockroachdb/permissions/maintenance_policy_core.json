{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EKSClusterCreate",
      "Effect": "Allow",
      "Action": ["eks:CreateCluster", "eks:CreateAddon", "eks:TagResource"],
      "Resource": "*"
    },
    {
      "Sid": "EKSClusterReadOnly",
      "Effect": "Allow",
      "Action": [
        "eks:DescribeCluster",
        "eks:ListClusters",
        "eks:DescribeAddon",
        "eks:DescribeAddonVersions",
        "eks:ListAddons",
        "eks:DescribeUpdate",
        "eks:ListUpdates",
        "eks:DescribeIdentityProviderConfig",
        "eks:ListIdentityProviderConfigs",
        "eks:ListTagsForResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EKSClusterModifyTagged",
      "Effect": "Allow",
      "Action": [
        "eks:DeleteCluster",
        "eks:UpdateClusterConfig",
        "eks:UpdateClusterVersion",
        "eks:DeleteAddon",
        "eks:UpdateAddon",
        "eks:AssociateEncryptionConfig",
        "eks:AssociateIdentityProviderConfig",
        "eks:DisassociateIdentityProviderConfig",
        "eks:UntagResource"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EKSNodeGroupCreate",
      "Effect": "Allow",
      "Action": ["eks:CreateNodegroup"],
      "Resource": "*"
    },
    {
      "Sid": "EKSNodeGroupReadOnly",
      "Effect": "Allow",
      "Action": ["eks:DescribeNodegroup", "eks:ListNodegroups"],
      "Resource": "*"
    },
    {
      "Sid": "EKSNodeGroupModifyTagged",
      "Effect": "Allow",
      "Action": ["eks:DeleteNodegroup", "eks:UpdateNodegroupConfig", "eks:UpdateNodegroupVersion"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EKSFargateCreate",
      "Effect": "Allow",
      "Action": ["eks:CreateFargateProfile"],
      "Resource": "*"
    },
    {
      "Sid": "EKSFargateReadOnly",
      "Effect": "Allow",
      "Action": ["eks:DescribeFargateProfile", "eks:ListFargateProfiles"],
      "Resource": "*"
    },
    {
      "Sid": "EKSFargateModifyTagged",
      "Effect": "Allow",
      "Action": ["eks:DeleteFargateProfile"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EKSAccessCreate",
      "Effect": "Allow",
      "Action": ["eks:CreateAccessEntry", "eks:AssociateAccessPolicy"],
      "Resource": "*"
    },
    {
      "Sid": "EKSAccessReadOnly",
      "Effect": "Allow",
      "Action": [
        "eks:DescribeAccessEntry",
        "eks:ListAccessEntries",
        "eks:ListAssociatedAccessPolicies",
        "eks:ListAccessPolicies"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EKSAccessModifyTagged",
      "Effect": "Allow",
      "Action": ["eks:DeleteAccessEntry", "eks:UpdateAccessEntry", "eks:DisassociateAccessPolicy"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EKSPodIdentityCreate",
      "Effect": "Allow",
      "Action": ["eks:CreatePodIdentityAssociation"],
      "Resource": "*"
    },
    {
      "Sid": "EKSPodIdentityReadOnly",
      "Effect": "Allow",
      "Action": ["eks:DescribePodIdentityAssociation", "eks:ListPodIdentityAssociations"],
      "Resource": "*"
    },
    {
      "Sid": "EKSPodIdentityModifyTagged",
      "Effect": "Allow",
      "Action": ["eks:DeletePodIdentityAssociation"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "KMSCreate",
      "Effect": "Allow",
      "Action": ["kms:CreateKey", "kms:CreateAlias", "kms:TagResource"],
      "Resource": "*"
    },
    {
      "Sid": "KMSReadOnly",
      "Effect": "Allow",
      "Action": [
        "kms:DescribeKey",
        "kms:GetKeyPolicy",
        "kms:GetKeyRotationStatus",
        "kms:ListResourceTags",
        "kms:ListAliases",
        "kms:ListGrants"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KMSModifyTagged",
      "Effect": "Allow",
      "Action": [
        "kms:ScheduleKeyDeletion",
        "kms:DeleteAlias",
        "kms:UpdateAlias",
        "kms:UntagResource",
        "kms:EnableKeyRotation",
        "kms:CreateGrant",
        "kms:RevokeGrant"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "KMSUseTagged",
      "Effect": "Allow",
      "Action": ["kms:Encrypt", "kms:Decrypt", "kms:GenerateDataKey", "kms:GenerateDataKeyWithoutPlaintext"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EC2ComputeCreate",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateFleet",
        "ec2:CreateLaunchTemplate",
        "ec2:CreateLaunchTemplateVersion",
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateSnapshot",
        "ec2:CreateSecurityGroup"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EC2ComputeReadOnly",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeLaunchTemplates",
        "ec2:DescribeLaunchTemplateVersions",
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceTypes",
        "ec2:DescribeInstanceTypeOfferings",
        "ec2:DescribeSpotPriceHistory",
        "ec2:DescribeImages",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeVolumes",
        "ec2:DescribeVolumesModifications",
        "ec2:DescribeSnapshots",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSecurityGroupRules",
        "ec2:DescribeVpcs",
        "ec2:DescribeSubnets",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DescribeRouteTables",
        "ec2:DescribeKeyPairs",
        "ec2:DescribeTags"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EC2ComputeModifyTagged",
      "Effect": "Allow",
      "Action": [
        "ec2:DeleteLaunchTemplate",
        "ec2:DeleteLaunchTemplateVersions",
        "ec2:ModifyLaunchTemplate",
        "ec2:TerminateInstances",
        "ec2:DeleteVolume",
        "ec2:AttachVolume",
        "ec2:DetachVolume",
        "ec2:ModifyVolume",
        "ec2:DeleteSnapshot",
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:ModifySecurityGroupRules"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "EC2Tagging",
      "Effect": "Allow",
      "Action": ["ec2:CreateTags"],
      "Resource": "*"
    },
    {
      "Sid": "EC2UntagTagged",
      "Effect": "Allow",
      "Action": ["ec2:DeleteTags"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "AutoScalingCreate",
      "Effect": "Allow",
      "Action": ["autoscaling:CreateAutoScalingGroup", "autoscaling:CreateOrUpdateTags"],
      "Resource": "*"
    },
    {
      "Sid": "AutoScalingReadOnly",
      "Effect": "Allow",
      "Action": [
        "autoscaling:DescribeAutoScalingGroups",
        "autoscaling:DescribeTags",
        "autoscaling:DescribeLaunchConfigurations",
        "autoscaling:DescribeScalingActivities"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AutoScalingModifyTagged",
      "Effect": "Allow",
      "Action": [
        "autoscaling:DeleteAutoScalingGroup",
        "autoscaling:UpdateAutoScalingGroup",
        "autoscaling:SetDesiredCapacity",
        "autoscaling:DeleteTags"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "KarpenterSSMForAMI",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters", "ssm:DescribeParameters"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterPricing",
      "Effect": "Allow",
      "Action": ["pricing:GetProducts"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterSQSCreate",
      "Effect": "Allow",
      "Action": ["sqs:CreateQueue", "sqs:TagQueue"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterSQSReadOnly",
      "Effect": "Allow",
      "Action": ["sqs:GetQueueAttributes", "sqs:GetQueueUrl", "sqs:ListQueueTags"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterSQSModifyTagged",
      "Effect": "Allow",
      "Action": [
        "sqs:DeleteQueue",
        "sqs:SetQueueAttributes",
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:UntagQueue"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "KarpenterEventBridgeCreate",
      "Effect": "Allow",
      "Action": ["events:PutRule", "events:PutTargets", "events:TagResource"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterEventBridgeReadOnly",
      "Effect": "Allow",
      "Action": ["events:DescribeRule", "events:ListRules", "events:ListTargetsByRule"],
      "Resource": "*"
    },
    {
      "Sid": "KarpenterEventBridgeModifyTagged",
      "Effect": "Allow",
      "Action": ["events:DeleteRule", "events:RemoveTargets", "events:UntagResource"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{.nuon.install.id}}"
        }
      }
    },
    {
      "Sid": "ALBManagement",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:DeleteLoadBalancer",
        "elasticloadbalancing:DescribeLoadBalancers",
        "elasticloadbalancing:ModifyLoadBalancerAttributes",
        "elasticloadbalancing:DescribeLoadBalancerAttributes",
        "elasticloadbalancing:SetSecurityGroups",
        "elasticloadbalancing:SetSubnets",
        "elasticloadbalancing:SetIpAddressType",
        "elasticloadbalancing:CreateTargetGroup",
        "elasticloadbalancing:DeleteTargetGroup",
        "elasticloadbalancing:DescribeTargetGroups",
        "elasticloadbalancing:ModifyTargetGroup",
        "elasticloadbalancing:ModifyTargetGroupAttributes",
        "elasticloadbalancing:DescribeTargetGroupAttributes",
        "elasticloadbalancing:DescribeTargetHealth",
        "elasticloadbalancing:RegisterTargets",
        "elasticloadbalancing:DeregisterTargets",
        "elasticloadbalancing:CreateListener",
        "elasticloadbalancing:DeleteListener",
        "elasticloadbalancing:DescribeListeners",
        "elasticloadbalancing:DescribeListenerAttributes",
        "elasticloadbalancing:ModifyListener",
        "elasticloadbalancing:ModifyListenerAttributes",
        "elasticloadbalancing:CreateRule",
        "elasticloadbalancing:DeleteRule",
        "elasticloadbalancing:DescribeRules",
        "elasticloadbalancing:ModifyRule",
        "elasticloadbalancing:SetRulePriorities",
        "elasticloadbalancing:AddTags",
        "elasticloadbalancing:RemoveTags",
        "elasticloadbalancing:DescribeTags",
        "elasticloadbalancing:DescribeSSLPolicies",
        "elasticloadbalancing:DescribeAccountLimits"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ACMCertificateManagement",
      "Effect": "Allow",
      "Action": [
        "acm:RequestCertificate",
        "acm:DeleteCertificate",
        "acm:DescribeCertificate",
        "acm:ListCertificates",
        "acm:ListTagsForCertificate",
        "acm:AddTagsToCertificate",
        "acm:RemoveTagsFromCertificate"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Route53Management",
      "Effect": "Allow",
      "Action": [
        "route53:ChangeResourceRecordSets",
        "route53:GetHostedZone",
        "route53:ListHostedZones",
        "route53:ListResourceRecordSets",
        "route53:GetChange"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsManagement",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:DeleteLogGroup",
        "logs:DescribeLogGroups",
        "logs:PutRetentionPolicy",
        "logs:DeleteRetentionPolicy",
        "logs:TagLogGroup",
        "logs:UntagLogGroup",
        "logs:ListTagsLogGroup",
        "logs:TagResource",
        "logs:UntagResource",
        "logs:ListTagsForResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECRRepositoryManagement",
      "Effect": "Allow",
      "Action": [
        "ecr:CreateRepository",
        "ecr:DeleteRepository",
        "ecr:DescribeRepositories",
        "ecr:ListTagsForResource",
        "ecr:TagResource",
        "ecr:UntagResource",
        "ecr:PutLifecyclePolicy",
        "ecr:GetLifecyclePolicy",
        "ecr:DeleteLifecyclePolicy",
        "ecr:SetRepositoryPolicy",
        "ecr:GetRepositoryPolicy",
        "ecr:DeleteRepositoryPolicy"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECRImageRead",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken",
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:DescribeImages"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECRImagePush",
      "Effect": "Allow",
      "Action": [
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage",
        "ecr:BatchCheckLayerAvailability"
      ],
      "Resource": "arn:aws:ecr:*:*:repository/{{.nuon.install.id}}"
    },
    {
      "Sid": "STSForOIDC",
      "Effect": "Allow",
      "Action": ["sts:GetCallerIdentity", "sts:AssumeRoleWithWebIdentity"],
      "Resource": "*"
    }
  ]
}
